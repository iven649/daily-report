<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>分销日报 - {{ date }}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; background: #f5f7fa; color: #222; }
    .container { max-width: 1100px; margin: 0 auto; padding: 24px; }
    .card { background: white; border-radius: 14px; padding: 20px; margin-bottom: 18px; box-shadow: 0 2px 10px rgba(0,0,0,.06);}
    .header { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; }
    .badges a { text-decoration:none; background:#222; color:#fff; padding:10px 14px; border-radius:10px; margin-right:8px; display:inline-block; }
    .grid2 { display:grid; grid-template-columns: 1fr 1fr; gap:16px; }
    .grid3 { display:grid; grid-template-columns: repeat(3, 1fr); gap:12px; }
    .section-title { font-size: 20px; margin-bottom: 14px; }
    .item { padding: 12px 0; border-bottom: 1px solid #eee; }
    .item:last-child { border-bottom: none; }
    .source { color:#666; font-size:12px; }
    a { color:#0a58ca; }
    .product { border:1px solid #eee; border-radius:12px; padding:14px; background:#fff; }
    .weather-box { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    .muted { color:#666; }
    @media (max-width: 900px) { .grid2, .grid3, .weather-box { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
<div class="container">
  <div class="card header">
    <div>
      <h1 style="margin:0;">分销日报</h1>
      <div class="muted">{{ date }}</div>
    </div>
    <div class="badges">
      {% for f in festival_cards %}
      <a href="{{ f.slug }}.html">{{ f.icon }} {{ f.name }} {{ f.countdown }}天</a>
      {% endfor %}
    </div>
  </div>

  <div class="weather-box">
    <div class="card">
      <h2 class="section-title">🌤️ 中国天气</h2>
      <div id="cn-weather">加载中...</div>
    </div>
    <div class="card">
      <h2 class="section-title">🌤️ 美国天气</h2>
      <div id="us-weather">加载中...</div>
    </div>
  </div>

  <div class="card">
    <h2 class="section-title">🕐 美国时区</h2>
    <div class="grid3">
      <div>东部 EST：<span id="tz-east"></span></div>
      <div>中部 CST：<span id="tz-central"></span></div>
      <div>山地 MST：<span id="tz-mountain"></span></div>
      <div>太平洋 PST：<span id="tz-pacific"></span></div>
      <div>阿拉斯加 AKST：<span id="tz-alaska"></span></div>
      <div>夏威夷 HST：<span id="tz-hawaii"></span></div>
    </div>
  </div>

  <div class="grid2">
    <div class="card">
      <h2 class="section-title">📱 今日热点</h2>
      {% for item in consumer_electronics %}
      <div class="item">
        <a href="{{ item.url }}" target="_blank">{{ item.display_title }}</a>
        <div class="source">{{ item.source }}</div>
      </div>
      {% endfor %}
    </div>
    <div class="card">
      <h2 class="section-title">🛒 渠道新闻</h2>
      {% for item in channel_news %}
      <div class="item">
        <a href="{{ item.url }}" target="_blank">{{ item.display_title }}</a>
        <div class="source">{{ item.source }}</div>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="card">
    <h2 class="section-title">🚀 新品速递</h2>
    <div class="grid3">
      {% for item in products %}
      <div class="product">
        <div><strong>{{ item.name }}</strong></div>
        <div class="muted">{{ item.source }} · {{ item.date }}</div>
        <p>{{ item.summary }}</p>
        <a href="{{ item.url }}" target="_blank">查看原文</a>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
async function loadWeather(city, id){
  try{
    const res = await fetch("https://goweather.herokuapp.com/weather/" + city);
    const data = await res.json();
    document.getElementById(id).textContent =
      city + " " + data.temperature + " " + data.description;
  }catch(e){
    document.getElementById(id).textContent = "天气获取失败";
  }
}
function updateTimezones(){
  const now = new Date();
  const utcH = now.getUTCHours();
  const m = String(now.getUTCMinutes()).padStart(2,'0');
  const zones = [
    ['tz-east', -4], ['tz-central', -5], ['tz-mountain', -6],
    ['tz-pacific', -7], ['tz-alaska', -8], ['tz-hawaii', -10]
  ];
  zones.forEach(([id, off]) => {
    let h = utcH + off; if(h < 0) h += 24; if(h >= 24) h -= 24;
    document.getElementById(id).textContent = h + ':' + m;
  });
}
loadWeather("Shenzhen","cn-weather");
loadWeather("Los Angeles","us-weather");
updateTimezones();
setInterval(updateTimezones, 60000);
</script>
</body>
</html>
