<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>分销日报 - {{ date }}</title>
  <style>
    :root {
      --bg: #f5f5f7;
      --bg-2: #fafafa;
      --card: rgba(255, 255, 255, 0.78);
      --card-solid: #ffffff;
      --text: #111111;
      --muted: #6e6e73;
      --muted-2: #8e8e93;
      --line: rgba(17, 17, 17, 0.08);
      --line-soft: rgba(17, 17, 17, 0.05);
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
      --shadow-soft: 0 4px 18px rgba(15, 23, 42, 0.035);
      --radius-2xl: 28px;
      --radius-xl: 22px;
      --radius-lg: 18px;
      --radius-md: 14px;
      --link: #161616;
      --link-hover: #4b5563;
      --accent: #111111;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      color: var(--text);
      background:
        linear-gradient(to right, rgba(17,17,17,0.03) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(17,17,17,0.03) 1px, transparent 1px),
        linear-gradient(180deg, #fcfcfd 0%, #f5f5f7 100%);
      background-size: 40px 40px, 40px 40px, auto;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI",
        "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .page {
      max-width: 1240px;
      margin: 0 auto;
      padding: 28px 20px 60px;
    }

    .glass {
      background: var(--card);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.65);
      box-shadow: var(--shadow);
      border-radius: var(--radius-2xl);
    }

    .section-card {
      background: var(--card-solid);
      border: 1px solid var(--line-soft);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-soft);
    }

    .hero {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 22px;
      padding: 24px;
      margin-bottom: 18px;
    }

    .hero-main {
      padding: 12px 8px 6px 4px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.72);
      border: 1px solid rgba(17,17,17,0.06);
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 18px;
    }

    .hero-title {
      margin: 0;
      font-size: 44px;
      line-height: 0.98;
      letter-spacing: -0.06em;
      font-weight: 720;
    }

    .hero-sub {
      margin-top: 14px;
      max-width: 640px;
      font-size: 15px;
      line-height: 1.8;
      color: var(--muted);
    }

    .hero-side {
      display: flex;
      flex-direction: column;
      gap: 16px;
      justify-content: space-between;
    }

    .date-card {
      background: rgba(255,255,255,0.7);
      border: 1px solid rgba(17,17,17,0.06);
      border-radius: var(--radius-xl);
      padding: 18px 18px 16px;
    }

    .date-label {
      font-size: 12px;
      color: var(--muted-2);
      margin-bottom: 6px;
    }

    .date-value {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.04em;
    }

    .festival-list {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .festival-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 14px;
      border-radius: 999px;
      background: #111111;
      color: #ffffff;
      font-size: 14px;
      font-weight: 600;
      box-shadow: 0 8px 18px rgba(17,17,17,0.12);
      transition: transform 0.16s ease, opacity 0.16s ease;
    }

    .festival-pill:hover {
      transform: translateY(-1px);
      opacity: 0.95;
    }

    .dashboard-row {
      display: grid;
      grid-template-columns: 0.95fr 1.05fr;
      gap: 18px;
      margin-bottom: 18px;
      align-items: start;
    }

    .timezone-card {
      padding: 22px;
      min-height: 100%;
    }

    .section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 16px;
    }

    .section-title {
      margin: 0;
      font-size: 18px;
      line-height: 1.2;
      letter-spacing: -0.02em;
      font-weight: 700;
    }

    .section-meta {
      font-size: 12px;
      color: var(--muted-2);
    }

    .timezone-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .timezone-item {
      background: linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
      border: 1px solid var(--line-soft);
      border-radius: var(--radius-lg);
      padding: 14px 14px 12px;
    }

    .timezone-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 8px;
      font-weight: 500;
    }

    .timezone-value {
      font-size: 28px;
      line-height: 1;
      font-weight: 720;
      letter-spacing: -0.05em;
    }

    .intro-card {
      padding: 22px;
      min-height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .intro-text {
      margin: 0;
      font-size: 16px;
      line-height: 1.9;
      color: #2c2c2e;
      max-width: 560px;
    }

    .intro-divider {
      width: 56px;
      height: 2px;
      background: linear-gradient(90deg, #111111 0%, rgba(17,17,17,0.15) 100%);
      border-radius: 999px;
      margin: 22px 0 18px;
    }

    .intro-note {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
    }

    .news-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 18px;
    }

    .news-card {
      padding: 22px 22px 10px;
    }

    .news-list {
      display: flex;
      flex-direction: column;
    }

    .news-item {
      padding: 16px 0;
      border-bottom: 1px solid var(--line-soft);
    }

    .news-item:last-child {
      border-bottom: none;
    }

    .news-index {
      font-size: 12px;
      color: var(--muted-2);
      margin-bottom: 8px;
      letter-spacing: 0.04em;
    }

    .news-title {
      display: inline-block;
      font-size: 17px;
      line-height: 1.5;
      letter-spacing: -0.015em;
      font-weight: 620;
      color: var(--link);
      transition: color 0.15s ease;
      margin-bottom: 7px;
    }

    .news-title:hover {
      color: var(--link-hover);
    }

    .news-source {
      font-size: 13px;
      color: var(--muted);
    }

    .products-card {
      padding: 22px;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      min-height: 255px;
      padding: 18px;
      border-radius: var(--radius-xl);
      border: 1px solid var(--line-soft);
      background:
        radial-gradient(circle at top right, rgba(17,17,17,0.035) 0%, transparent 36%),
        linear-gradient(180deg, #ffffff 0%, #fcfcfc 100%);
      transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
    }

    .product-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 30px rgba(15, 23, 42, 0.055);
      border-color: rgba(17,17,17,0.08);
    }

    .product-kicker {
      font-size: 11px;
      letter-spacing: 0.06em;
      color: var(--muted-2);
      margin-bottom: 10px;
      text-transform: uppercase;
    }

    .product-title {
      font-size: 19px;
      line-height: 1.42;
      letter-spacing: -0.02em;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .product-meta {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .product-summary {
      flex: 1;
      font-size: 14px;
      line-height: 1.72;
      color: #3f3f46;
      margin-bottom: 18px;
    }

    .product-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      font-weight: 600;
      color: var(--link);
      transition: color 0.15s ease;
    }

    .product-link:hover {
      color: var(--link-hover);
    }

    .empty-text {
      color: var(--muted);
      font-size: 14px;
      padding: 12px 0 18px;
    }

    @media (max-width: 1024px) {
      .hero,
      .dashboard-row,
      .news-grid,
      .products-grid {
        grid-template-columns: 1fr;
      }

      .hero-title {
        font-size: 38px;
      }

      .timezone-grid {
        grid-template-columns: 1fr 1fr 1fr;
      }
    }

    @media (max-width: 760px) {
      .page {
        padding: 18px 14px 40px;
      }

      .hero,
      .timezone-card,
      .intro-card,
      .news-card,
      .products-card {
        padding: 18px;
      }

      .hero-title {
        font-size: 30px;
      }

      .timezone-grid,
      .products-grid {
        grid-template-columns: 1fr;
      }

      .festival-list {
        gap: 10px;
      }

      .festival-pill {
        font-size: 13px;
      }

      .news-title {
        font-size: 16px;
      }

      .product-title {
        font-size: 17px;
      }
    }
  </style>
</head>
<body>
  <div class="page">

    <!-- 顶部 -->
    <div class="glass hero">
      <div class="hero-main">
        <div class="eyebrow">
          <span>Daily Intelligence Brief</span>
        </div>
        <h1 class="hero-title">分销日报</h1>
        <div class="hero-sub">
          聚合消费电子动态、渠道侧变化与新品信息，以更克制的版式呈现当日值得关注的核心信号。
        </div>
      </div>

      <div class="hero-side">
        <div class="date-card">
          <div class="date-label">Date</div>
          <div class="date-value">{{ date }}</div>
        </div>

        <div class="festival-list">
          {% for f in festival_cards %}
          <a class="festival-pill" href="{{ f.slug }}.html">
            <span>{{ f.icon }}</span>
            <span>{{ f.name }} {{ f.countdown }}天</span>
          </a>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- 顶部辅助区 -->
    <div class="dashboard-row">
      <div class="section-card timezone-card">
        <div class="section-head">
          <h2 class="section-title">🕐 美国时区</h2>
          <div class="section-meta">实时更新</div>
        </div>

        <div class="timezone-grid">
          <div class="timezone-item">
            <div class="timezone-label">东部 EST</div>
            <div id="tz-east" class="timezone-value">--:--</div>
          </div>
          <div class="timezone-item">
            <div class="timezone-label">中部 CST</div>
            <div id="tz-central" class="timezone-value">--:--</div>
          </div>
          <div class="timezone-item">
            <div class="timezone-label">山地 MST</div>
            <div id="tz-mountain" class="timezone-value">--:--</div>
          </div>
          <div class="timezone-item">
            <div class="timezone-label">太平洋 PST</div>
            <div id="tz-pacific" class="timezone-value">--:--</div>
          </div>
          <div class="timezone-item">
            <div class="timezone-label">阿拉斯加 AKST</div>
            <div id="tz-alaska" class="timezone-value">--:--</div>
          </div>
          <div class="timezone-item">
            <div class="timezone-label">夏威夷 HST</div>
            <div id="tz-hawaii" class="timezone-value">--:--</div>
          </div>
        </div>
      </div>

      <div class="section-card intro-card">
        <div>
          <div class="section-head">
            <h2 class="section-title">Overview</h2>
          </div>
          <p class="intro-text">
            重点关注消费电子硬件、渠道侧经营信号与新品发布节奏，帮助团队更快判断哪些信息值得跟进、讨论与转化。
          </p>
          <div class="intro-divider"></div>
        </div>
        <div class="intro-note">
          当前页面已简化为更高密度的阅读结构，适合晨会浏览、日报归档与链接分享。
        </div>
      </div>
    </div>

    <!-- 新闻 -->
    <div class="news-grid">
      <div class="section-card news-card">
        <div class="section-head">
          <h2 class="section-title">📰 今日热点</h2>
        </div>

        <div class="news-list">
          {% if consumer_electronics %}
            {% for item in consumer_electronics %}
            <div class="news-item">
              <div class="news-index">{{ "%02d" % loop.index }}</div>
              <a class="news-title" href="{{ item.url }}" target="_blank" rel="noreferrer">
                {{ item.display_title or item.title }}
              </a>
              <div class="news-source">{{ item.source }}</div>
            </div>
            {% endfor %}
          {% else %}
            <div class="empty-text">暂无内容</div>
          {% endif %}
        </div>
      </div>

      <div class="section-card news-card">
        <div class="section-head">
          <h2 class="section-title">🛒 渠道新闻</h2>
        </div>

        <div class="news-list">
          {% if channel_news %}
            {% for item in channel_news %}
            <div class="news-item">
              <div class="news-index">{{ "%02d" % loop.index }}</div>
              <a class="news-title" href="{{ item.url }}" target="_blank" rel="noreferrer">
                {{ item.display_title or item.title }}
              </a>
              <div class="news-source">{{ item.source }}</div>
            </div>
            {% endfor %}
          {% else %}
            <div class="empty-text">暂无内容</div>
          {% endif %}
        </div>
      </div>
    </div>

    <!-- 新品速递 -->
    <div class="section-card products-card">
      <div class="section-head">
        <h2 class="section-title">🚀 新品速递</h2>
      </div>

      <div class="products-grid">
        {% if products %}
          {% for item in products %}
          <div class="product-card">
            <div class="product-kicker">Product {{ "%02d" % loop.index }}</div>

            <div class="product-title">
              {{ item.display_title or item.name }}
            </div>

            <div class="product-meta">
              {{ item.source }} · {{ item.date }}
            </div>

            <div class="product-summary">
              {{ item.display_summary or item.summary }}
            </div>

            <a href="{{ item.url }}" target="_blank" rel="noreferrer" class="product-link">
              <span>查看原文</span>
              <span>→</span>
            </a>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty-text">暂无新品内容</div>
        {% endif %}
      </div>
    </div>

  </div>

  <script>
    function updateTimezones() {
      const now = new Date();
      const utcHour = now.getUTCHours();
      const minute = String(now.getUTCMinutes()).padStart(2, "0");

      const zones = [
        ["tz-east", -4],
        ["tz-central", -5],
        ["tz-mountain", -6],
        ["tz-pacific", -7],
        ["tz-alaska", -8],
        ["tz-hawaii", -10]
      ];

      zones.forEach(([id, offset]) => {
        let hour = utcHour + offset;
        if (hour < 0) hour += 24;
        if (hour >= 24) hour -= 24;

        const text = `${hour}:${minute}`;
        const el = document.getElementById(id);
        if (el) el.textContent = text;
      });
    }

    updateTimezones();
    setInterval(updateTimezones, 60000);
  </script>
</body>
</html>
