<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>北美业务情报日报</title>

<style>
body {
  font-family: -apple-system, BlinkMacSystemFont;
  background: #f5f5f7;
  margin: 0;
}

.page {
  max-width: 1200px;
  margin: auto;
  padding: 20px;
}

.card {
  background: white;
  border-radius: 24px;
  padding: 20px;
  margin-bottom: 20px;
}

.section-head {
  display: flex;
  justify-content: center;
  margin-bottom: 15px;
}

.section-jump {
  font-size: 18px;
  font-weight: 700;
  padding: 6px 12px;
  border-radius: 999px;
  transition: 0.2s;
}

.section-jump:hover {
  background: #f0f0f0;
  transform: translateY(-1px);
}

.section-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.news-item {
  padding: 12px 0;
  border-bottom: 1px solid #eee;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.product-card {
  border: 1px solid #eee;
  border-radius: 16px;
  padding: 16px;
}

.tz-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.tz-link {
  display: block;
  padding: 10px;
  border-radius: 12px;
  background: #fafafa;
}

.feedback-link {
  display: block;
  padding: 20px;
  background: #fafafa;
  border-radius: 16px;
  text-align: center;
}

html {
  scroll-behavior: smooth;
}

#section-consumer,
#section-channel,
#section-products,
#section-watch {
  scroll-margin-top: 100px;
}
</style>
</head>

<body>

<div class="page">

<!-- HEADER -->
<div class="card">
  <h1>北美业务情报日报</h1>

  <h2>{{ lead_summary }}</h2>

  <!-- 时区 -->
  <div>
    <div>北京时间: <span id="bj"></span></div>

    <div class="tz-grid">
      <a class="tz-link" href="https://www.timeanddate.com/worldclock/usa/new-york" target="_blank">
        ET <div id="et"></div>
      </a>

      <a class="tz-link" href="https://www.timeanddate.com/worldclock/usa/chicago" target="_blank">
        CT <div id="ct"></div>
      </a>

      <a class="tz-link" href="https://www.timeanddate.com/worldclock/usa/denver" target="_blank">
        MT <div id="mt"></div>
      </a>

      <a class="tz-link" href="https://www.timeanddate.com/worldclock/usa/los-angeles" target="_blank">
        PT <div id="pt"></div>
      </a>

      <a class="tz-link" href="https://www.timeanddate.com/worldclock/usa/anchorage" target="_blank">
        AKT <div id="akt"></div>
      </a>

      <a class="tz-link" href="https://www.timeanddate.com/worldclock/usa/honolulu" target="_blank">
        HST <div id="hst"></div>
      </a>
    </div>
  </div>
</div>

<!-- 4 BLOCKS -->
<div class="section-row">

  <div class="card">
    <div class="section-head">
      <a class="section-jump" href="#section-watch">头条三条</a>
    </div>
    {% for item in headline_trio %}
    <div class="news-item">
      {{ item.display_title }}
    </div>
    {% endfor %}
  </div>

  <div class="card">
    <div class="section-head">
      <a class="section-jump" href="#section-consumer">今日重点</a>
    </div>
    {% for item in takeaways %}
    <div>{{ item }}</div>
    {% endfor %}
  </div>

</div>

<div class="section-row">

  <div class="card">
    <div class="section-head">
      <a class="section-jump" href="#section-products">机会提示</a>
    </div>
    {% for item in opportunity_signals %}
    <div>{{ item }}</div>
    {% endfor %}
  </div>

  <div class="card">
    <div class="section-head">
      <a class="section-jump" href="#section-channel">风险提示</a>
    </div>
    {% for item in risk_signals %}
    <div>{{ item }}</div>
    {% endfor %}
  </div>

</div>

<!-- 监控 -->
<div id="section-watch" class="card">
  <h2>竞品 / 平台动态</h2>
</div>

<!-- 消费电子 -->
<div id="section-consumer" class="card">
  <h2>消费电子</h2>
  {% for item in consumer_electronics %}
  <div class="news-item">{{ item.display_title }}</div>
  {% endfor %}
</div>

<!-- 渠道 -->
<div id="section-channel" class="card">
  <h2>渠道 / 平台</h2>
  {% for item in channel_news %}
  <div class="news-item">{{ item.display_title }}</div>
  {% endfor %}
</div>

<!-- 新品 -->
<div id="section-products" class="card">
  <h2>新品速递</h2>

  <div class="product-grid">
    {% for item in products %}
    <div class="product-card">
      {{ item.display_title }}
    </div>
    {% endfor %}
  </div>
</div>

<!-- FEEDBACK -->
<div class="card">
  <a class="feedback-link"
     href="https://docs.google.com/forms/d/e/1FAIpQLSdyWZwDTGRplMGv6EWojLPp3VjaKpsv_DqKaS0XyXiayPf7hg/viewform?usp=dialog"
     target="_blank">
     点击提交反馈
  </a>
</div>

</div>

<script>
function t(tz){return new Intl.DateTimeFormat("zh-CN",{timeZone:tz,hour:"2-digit",minute:"2-digit"}).format(new Date())}

function u(){
  bj.textContent=t("Asia/Shanghai")
  et.textContent=t("America/New_York")
  ct.textContent=t("America/Chicago")
  mt.textContent=t("America/Denver")
  pt.textContent=t("America/Los_Angeles")
  akt.textContent=t("America/Anchorage")
  hst.textContent=t("Pacific/Honolulu")
}

u();setInterval(u,1000)
</script>

</body>
</html>
