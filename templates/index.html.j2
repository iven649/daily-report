<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>分销日报 - {{ date }}</title>
  <style>
    :root {
      --bg: #f5f5f7;
      --card: #ffffff;
      --text: #111111;
      --muted: #6e6e73;
      --muted-2: #8e8e93;
      --line: #e8e8ed;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
      --radius-xl: 24px;
      --radius-lg: 20px;
      --radius-md: 16px;
      --radius-sm: 12px;
      --link: #1d1d1f;
      --link-hover: #4b5563;
      --surface: #fafafa;
      --surface-2: #f7f7f8;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI",
        "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .page {
      max-width: 1180px;
      margin: 0 auto;
      padding: 28px 20px 52px;
    }

    .card {
      background: var(--card);
      border: 1px solid rgba(17, 17, 17, 0.04);
      box-shadow: var(--shadow);
      border-radius: var(--radius-xl);
    }

    .hero {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 24px;
      padding: 26px 28px;
      margin-bottom: 18px;
    }

    .hero-title {
      margin: 0;
      font-size: 32px;
      line-height: 1.05;
      letter-spacing: -0.04em;
      font-weight: 700;
    }

    .hero-date {
      margin-top: 10px;
      color: var(--muted);
      font-size: 15px;
      font-weight: 500;
    }

    .festival-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: flex-end;
    }

    .festival-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      background: #111111;
      color: #ffffff;
      font-size: 14px;
      font-weight: 600;
      white-space: nowrap;
      transition: transform 0.15s ease, opacity 0.15s ease;
    }

    .festival-badge:hover {
      transform: translateY(-1px);
      opacity: 0.94;
    }

    .timezone-card {
      padding: 24px 24px 22px;
      margin-bottom: 18px;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 16px;
    }

    .section-title {
      margin: 0;
      font-size: 18px;
      line-height: 1.2;
      letter-spacing: -0.02em;
      font-weight: 700;
    }

    .section-note {
      color: var(--muted-2);
      font-size: 13px;
    }

    .timezone-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .timezone-item {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: 14px 14px 12px;
      min-height: 84px;
    }

    .timezone-label {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 10px;
      font-weight: 500;
    }

    .timezone-value {
      font-size: 28px;
      line-height: 1;
      letter-spacing: -0.04em;
      font-weight: 700;
      color: var(--text);
    }

    .news-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 18px;
    }

    .news-card {
      padding: 24px 24px 8px;
      min-height: 460px;
    }

    .news-list {
      display: flex;
      flex-direction: column;
    }

    .news-item {
      padding: 16px 0;
      border-bottom: 1px solid var(--line);
    }

    .news-item:last-child {
      border-bottom: none;
    }

    .news-title {
      display: inline-block;
      font-size: 17px;
      line-height: 1.45;
      letter-spacing: -0.01em;
      font-weight: 600;
      color: var(--link);
      transition: color 0.15s ease;
      margin-bottom: 8px;
    }

    .news-title:hover {
      color: var(--link-hover);
    }

    .news-meta {
      font-size: 13px;
      color: var(--muted);
    }

    .empty-text {
      color: var(--muted);
      font-size: 14px;
      padding: 12px 0 18px;
    }

    .products-card {
      padding: 24px;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      min-height: 248px;
      padding: 18px 18px 16px;
      border-radius: var(--radius-lg);
      background: linear-gradient(180deg, #ffffff 0%, #fbfbfc 100%);
      border: 1px solid var(--line);
      transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
    }

    .product-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
      border-color: #e3e3e8;
    }

    .product-title {
      font-size: 18px;
      line-height: 1.42;
      letter-spacing: -0.02em;
      font-weight: 700;
      margin-bottom: 10px;
      color: var(--text);
    }

    .product-meta {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .product-summary {
      flex: 1;
      font-size: 14px;
      line-height: 1.68;
      color: #3f3f46;
      margin-bottom: 18px;
    }

    .product-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      font-weight: 600;
      color: var(--link);
      transition: color 0.15s ease;
    }

    .product-link:hover {
      color: var(--link-hover);
    }

    @media (max-width: 980px) {
      .news-layout,
      .products-grid {
        grid-template-columns: 1fr;
      }

      .timezone-grid {
        grid-template-columns: 1fr 1fr;
      }

      .hero {
        flex-direction: column;
        align-items: flex-start;
      }

      .festival-badges {
        justify-content: flex-start;
      }

      .news-card {
        min-height: auto;
      }
    }

    @media (max-width: 640px) {
      .page {
        padding: 18px 14px 40px;
      }

      .hero,
      .timezone-card,
      .news-card,
      .products-card {
        padding-left: 18px;
        padding-right: 18px;
      }

      .hero-title {
        font-size: 28px;
      }

      .timezone-grid {
        grid-template-columns: 1fr;
      }

      .timezone-value {
        font-size: 24px;
      }

      .news-title {
        font-size: 16px;
      }

      .product-title {
        font-size: 17px;
      }
    }
  </style>
</head>
<body>
  <div class="page">

    <!-- 顶部 -->
    <div class="card hero">
      <div>
        <h1 class="hero-title">分销日报</h1>
        <div class="hero-date">{{ date }}</div>
      </div>

      <div class="festival-badges">
        {% for f in festival_cards %}
        <a class="festival-badge" href="{{ f.slug }}.html">
          <span>{{ f.icon }}</span>
          <span>{{ f.name }} {{ f.countdown }}天</span>
        </a>
        {% endfor %}
      </div>
    </div>

    <!-- 美国时区 -->
    <div class="card timezone-card">
      <div class="section-header">
        <h2 class="section-title">🕐 美国时区</h2>
        <div class="section-note">每分钟自动刷新</div>
      </div>

      <div class="timezone-grid">
        <div class="timezone-item">
          <div class="timezone-label">东部 EST</div>
          <div id="tz-east" class="timezone-value">--:--</div>
        </div>
        <div class="timezone-item">
          <div class="timezone-label">中部 CST</div>
          <div id="tz-central" class="timezone-value">--:--</div>
        </div>
        <div class="timezone-item">
          <div class="timezone-label">山地 MST</div>
          <div id="tz-mountain" class="timezone-value">--:--</div>
        </div>
        <div class="timezone-item">
          <div class="timezone-label">太平洋 PST</div>
          <div id="tz-pacific" class="timezone-value">--:--</div>
        </div>
        <div class="timezone-item">
          <div class="timezone-label">阿拉斯加 AKST</div>
          <div id="tz-alaska" class="timezone-value">--:--</div>
        </div>
        <div class="timezone-item">
          <div class="timezone-label">夏威夷 HST</div>
          <div id="tz-hawaii" class="timezone-value">--:--</div>
        </div>
      </div>
    </div>

    <!-- 新闻 -->
    <div class="news-layout">
      <div class="card news-card">
        <div class="section-header">
          <h2 class="section-title">📰 今日热点</h2>
        </div>

        <div class="news-list">
          {% if consumer_electronics %}
            {% for item in consumer_electronics %}
            <div class="news-item">
              <a class="news-title" href="{{ item.url }}" target="_blank" rel="noreferrer">
                {{ item.display_title or item.title }}
              </a>
              <div class="news-meta">{{ item.source }}</div>
            </div>
            {% endfor %}
          {% else %}
            <div class="empty-text">暂无内容</div>
          {% endif %}
        </div>
      </div>

      <div class="card news-card">
        <div class="section-header">
          <h2 class="section-title">🛒 渠道新闻</h2>
        </div>

        <div class="news-list">
          {% if channel_news %}
            {% for item in channel_news %}
            <div class="news-item">
              <a class="news-title" href="{{ item.url }}" target="_blank" rel="noreferrer">
                {{ item.display_title or item.title }}
              </a>
              <div class="news-meta">{{ item.source }}</div>
            </div>
            {% endfor %}
          {% else %}
            <div class="empty-text">暂无内容</div>
          {% endif %}
        </div>
      </div>
    </div>

    <!-- 新品速递 -->
    <div class="card products-card">
      <div class="section-header">
        <h2 class="section-title">🚀 新品速递</h2>
      </div>

      <div class="products-grid">
        {% if products %}
          {% for item in products %}
          <div class="product-card">
            <div class="product-title">
              {{ item.display_title or item.name }}
            </div>

            <div class="product-meta">
              {{ item.source }} · {{ item.date }}
            </div>

            <div class="product-summary">
              {{ item.display_summary or item.summary }}
            </div>

            <a href="{{ item.url }}" target="_blank" rel="noreferrer" class="product-link">
              <span>查看原文</span>
              <span>→</span>
            </a>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty-text">暂无新品内容</div>
        {% endif %}
      </div>
    </div>

  </div>

  <script>
    function updateTimezones() {
      const now = new Date();
      const utcHour = now.getUTCHours();
      const minute = String(now.getUTCMinutes()).padStart(2, "0");

      const zones = [
        ["tz-east", -4],
        ["tz-central", -5],
        ["tz-mountain", -6],
        ["tz-pacific", -7],
        ["tz-alaska", -8],
        ["tz-hawaii", -10]
      ];

      zones.forEach(([id, offset]) => {
        let hour = utcHour + offset;
        if (hour < 0) hour += 24;
        if (hour >= 24) hour -= 24;

        document.getElementById(id).textContent = `${hour}:${minute}`;
      });
    }

    updateTimezones();
    setInterval(updateTimezones, 60000);
  </script>
</body>
</html>
