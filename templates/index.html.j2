<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>分销日报 - {{ date }}</title>
  <style>
    :root {
      --bg: #f5f5f7;
      --card: #ffffff;
      --text: #111111;
      --muted: #6b7280;
      --line: #ececec;
      --shadow: 0 6px 24px rgba(17, 17, 17, 0.05);
      --radius: 20px;
      --link: #2563eb;
      --badge: #111111;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC",
        "Hiragino Sans GB", "Microsoft YaHei", Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    a {
      color: var(--link);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    .container {
      max-width: 1180px;
      margin: 0 auto;
      padding: 28px 20px 56px;
    }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid rgba(17, 17, 17, 0.04);
    }

    .hero {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      padding: 22px 24px;
      margin-bottom: 18px;
    }

    .hero-title {
      margin: 0;
      font-size: 24px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .hero-date {
      margin-top: 6px;
      color: var(--muted);
      font-size: 15px;
    }

    .badges {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 14px;
      background: var(--badge);
      color: #fff;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      white-space: nowrap;
    }

    .badge:hover {
      text-decoration: none;
      opacity: 0.92;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 18px;
    }

    .section {
      padding: 22px 20px 20px;
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 0 0 18px;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .weather-search-wrap {
      position: relative;
      margin-bottom: 16px;
    }

    .weather-search-input {
      width: 100%;
      height: 46px;
      border: 1px solid var(--line);
      background: #fafafa;
      border-radius: 14px;
      padding: 0 14px;
      font-size: 14px;
      color: var(--text);
      outline: none;
      transition: all 0.2s ease;
    }

    .weather-search-input:focus {
      border-color: #d4d4d8;
      background: #fff;
      box-shadow: 0 0 0 4px rgba(17, 17, 17, 0.03);
    }

    .weather-dropdown {
      position: absolute;
      top: 52px;
      left: 0;
      right: 0;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      box-shadow: 0 10px 30px rgba(17, 17, 17, 0.08);
      overflow: hidden;
      z-index: 20;
      display: none;
      max-height: 240px;
      overflow-y: auto;
    }

    .weather-dropdown.show {
      display: block;
    }

    .weather-dropdown-item {
      padding: 12px 14px;
      font-size: 14px;
      cursor: pointer;
      color: var(--text);
      background: #fff;
      transition: background 0.15s ease;
    }

    .weather-dropdown-item:hover {
      background: #f7f7f8;
    }

    .weather-current-card {
      display: flex;
      align-items: center;
      gap: 16px;
      background: linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 18px 16px;
      margin-bottom: 14px;
    }

    .weather-current-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: #f7f7f8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      border: 1px solid var(--line);
      flex-shrink: 0;
    }

    .weather-current-main {
      min-width: 0;
      flex: 1;
    }

    .weather-current-city {
      font-size: 17px;
      font-weight: 700;
      margin-bottom: 4px;
      letter-spacing: -0.01em;
    }

    .weather-current-temp {
      font-size: 24px;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 4px;
    }

    .weather-current-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }

    .weather-forecast-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .weather-forecast-item {
      border: 1px solid var(--line);
      background: #fafafa;
      border-radius: 16px;
      padding: 14px 10px;
      text-align: center;
    }

    .weather-forecast-day {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .weather-forecast-icon {
      font-size: 24px;
      margin-bottom: 8px;
    }

    .weather-forecast-temp {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .weather-forecast-desc {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.4;
    }

    .timezone-card {
      padding: 22px 20px 20px;
      margin-bottom: 18px;
    }

    .timezone-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px 18px;
      margin-top: 8px;
    }

    .timezone-item {
      padding: 12px 14px;
      border-radius: 14px;
      background: #fafafa;
      border: 1px solid var(--line);
    }

    .timezone-name {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }

    .timezone-time {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .news-wrap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 18px;
    }

    .news-card {
      padding: 22px 20px 10px;
      min-height: 420px;
    }

    .news-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .news-item {
      padding: 14px 0;
      border-bottom: 1px solid var(--line);
    }

    .news-item:last-child {
      border-bottom: none;
    }

    .news-title {
      display: inline-block;
      font-size: 16px;
      line-height: 1.45;
      font-weight: 600;
      color: #1d4ed8;
      margin-bottom: 6px;
    }

    .news-source {
      color: var(--muted);
      font-size: 13px;
    }

    .products-card {
      padding: 22px 20px 20px;
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .product-card {
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 18px 16px;
      background: linear-gradient(180deg, #ffffff 0%, #fcfcfc 100%);
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      min-height: 240px;
      display: flex;
      flex-direction: column;
    }

    .product-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(17, 17, 17, 0.06);
      border-color: #e5e7eb;
    }

    .product-title {
      font-size: 18px;
      font-weight: 700;
      line-height: 1.4;
      letter-spacing: -0.01em;
      margin-bottom: 8px;
      color: var(--text);
    }

    .product-meta {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 14px;
    }

    .product-summary {
      color: #374151;
      font-size: 14px;
      line-height: 1.65;
      flex: 1;
      margin-bottom: 18px;
    }

    .product-link {
      font-size: 14px;
      font-weight: 600;
      align-self: flex-start;
    }

    .empty-text {
      color: var(--muted);
      font-size: 14px;
      padding: 10px 0 14px;
    }

    @media (max-width: 980px) {
      .two-col,
      .news-wrap,
      .products-grid {
        grid-template-columns: 1fr;
      }

      .timezone-grid {
        grid-template-columns: 1fr 1fr;
      }

      .hero {
        flex-direction: column;
        align-items: flex-start;
      }

      .badges {
        justify-content: flex-start;
      }

      .news-card {
        min-height: auto;
      }
    }

    @media (max-width: 640px) {
      .container {
        padding: 18px 14px 40px;
      }

      .hero,
      .section,
      .timezone-card,
      .news-card,
      .products-card {
        padding-left: 16px;
        padding-right: 16px;
      }
      .weather-current-card {
        padding: 16px 14px;
      }

      .weather-forecast-grid {
        grid-template-columns: 1fr;
      }

      .hero-title {
        font-size: 22px;
      }

      .timezone-grid {
        grid-template-columns: 1fr;
      }

      .product-title {
        font-size: 17px;
      }

      .news-title {
        font-size: 15px;
      }
    }
  </style>
</head>
<body>
<div class="container">

  <!-- 顶部 -->
  <div class="card hero">
    <div>
      <h1 class="hero-title">分销日报</h1>
      <div class="hero-date">{{ date }}</div>
    </div>

    <div class="badges">
      {% for f in festival_cards %}
      <a class="badge" href="{{ f.slug }}.html">
        <span>{{ f.icon }}</span>
        <span>{{ f.name }} {{ f.countdown }}天</span>
      </a>
      {% endfor %}
    </div>
  </div>

  <!-- 天气 -->
  <div class="two-col">
    <div class="card section">
      <h2 class="section-title">🌤️ 中国天气</h2>

      <div class="weather-search-wrap">
        <input
          id="cn-city-input"
          class="weather-search-input"
          type="text"
          placeholder="搜索中国城市"
          autocomplete="off"
        />
        <div id="cn-city-dropdown" class="weather-dropdown"></div>
      </div>

      <div class="weather-current-card">
        <div id="cn-weather-icon" class="weather-current-icon">☀️</div>
        <div class="weather-current-main">
          <div id="cn-weather-city" class="weather-current-city">深圳</div>
          <div id="cn-weather-temp" class="weather-current-temp">加载中...</div>
          <div id="cn-weather-desc" class="weather-current-desc"></div>
        </div>
      </div>

      <div id="cn-weather-forecast" class="weather-forecast-grid"></div>
    </div>

    <div class="card section">
      <h2 class="section-title">🌤️ 美国天气</h2>

      <div class="weather-search-wrap">
        <input
          id="us-city-input"
          class="weather-search-input"
          type="text"
          placeholder="Search US city"
          autocomplete="off"
        />
        <div id="us-city-dropdown" class="weather-dropdown"></div>
      </div>

      <div class="weather-current-card">
        <div id="us-weather-icon" class="weather-current-icon">☀️</div>
        <div class="weather-current-main">
          <div id="us-weather-city" class="weather-current-city">Los Angeles</div>
          <div id="us-weather-temp" class="weather-current-temp">Loading...</div>
          <div id="us-weather-desc" class="weather-current-desc"></div>
        </div>
      </div>

      <div id="us-weather-forecast" class="weather-forecast-grid"></div>
    </div>
  </div>

  <!-- 时区 -->
  <div class="card timezone-card">
    <h2 class="section-title">🕐 美国时区</h2>
    <div class="timezone-grid">
      <div class="timezone-item">
        <div class="timezone-name">东部 EST</div>
        <div id="tz-east" class="timezone-time"></div>
      </div>
      <div class="timezone-item">
        <div class="timezone-name">中部 CST</div>
        <div id="tz-central" class="timezone-time"></div>
      </div>
      <div class="timezone-item">
        <div class="timezone-name">山地 MST</div>
        <div id="tz-mountain" class="timezone-time"></div>
      </div>
      <div class="timezone-item">
        <div class="timezone-name">太平洋 PST</div>
        <div id="tz-pacific" class="timezone-time"></div>
      </div>
      <div class="timezone-item">
        <div class="timezone-name">阿拉斯加 AKST</div>
        <div id="tz-alaska" class="timezone-time"></div>
      </div>
      <div class="timezone-item">
        <div class="timezone-name">夏威夷 HST</div>
        <div id="tz-hawaii" class="timezone-time"></div>
      </div>
    </div>
  </div>

  <!-- 新闻 -->
  <div class="news-wrap">
    <div class="card news-card">
      <h2 class="section-title">📰 今日热点</h2>
      <div class="news-list">
        {% if consumer_electronics %}
          {% for item in consumer_electronics %}
          <div class="news-item">
            <a class="news-title" href="{{ item.url }}" target="_blank">
              {{ item.display_title or item.title }}
            </a>
            <div class="news-source">{{ item.source }}</div>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty-text">暂无内容</div>
        {% endif %}
      </div>
    </div>

    <div class="card news-card">
      <h2 class="section-title">🛒 渠道新闻</h2>
      <div class="news-list">
        {% if channel_news %}
          {% for item in channel_news %}
          <div class="news-item">
            <a class="news-title" href="{{ item.url }}" target="_blank">
              {{ item.display_title or item.title }}
            </a>
            <div class="news-source">{{ item.source }}</div>
          </div>
          {% endfor %}
        {% else %}
          <div class="empty-text">暂无内容</div>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- 新品速递 -->
  <div class="card products-card">
    <h2 class="section-title">🚀 新品速递</h2>

    <div class="products-grid">
      {% if products %}
        {% for item in products %}
        <div class="product-card">
          <div class="product-title">
            {{ item.display_title or item.name }}
          </div>

          <div class="product-meta">
            {{ item.source }} · {{ item.date }}
          </div>

          <div class="product-summary">
            {{ item.display_summary or item.summary }}
          </div>

          <a href="{{ item.url }}" target="_blank" class="product-link">
            查看原文 →
          </a>
        </div>
        {% endfor %}
      {% else %}
        <div class="empty-text">暂无新品内容</div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  const WEATHER_CITY_OPTIONS = {
    cn: [
      "Shenzhen", "Beijing", "Shanghai", "Guangzhou", "Hangzhou",
      "Chengdu", "Wuhan", "Xiamen", "Nanjing", "Suzhou"
    ],
    us: [
      "Los Angeles", "New York", "Seattle", "San Francisco", "Chicago",
      "Austin", "Boston", "Miami", "Dallas", "Denver"
    ]
  };

  const WEATHER_CITY_LABELS = {
    "Shenzhen": "深圳",
    "Beijing": "北京",
    "Shanghai": "上海",
    "Guangzhou": "广州",
    "Hangzhou": "杭州",
    "Chengdu": "成都",
    "Wuhan": "武汉",
    "Xiamen": "厦门",
    "Nanjing": "南京",
    "Suzhou": "苏州",
    "Los Angeles": "Los Angeles",
    "New York": "New York",
    "Seattle": "Seattle",
    "San Francisco": "San Francisco",
    "Chicago": "Chicago",
    "Austin": "Austin",
    "Boston": "Boston",
    "Miami": "Miami",
    "Dallas": "Dallas",
    "Denver": "Denver"
  };

  function weatherIconFromCode(code) {
    const c = Number(code);

    if ([0].includes(c)) return "☀️";
    if ([1, 2].includes(c)) return "⛅";
    if ([3].includes(c)) return "☁️";
    if ([45, 48].includes(c)) return "🌫️";
    if ([51, 53, 55, 56, 57].includes(c)) return "🌦️";
    if ([61, 63, 65, 66, 67, 80, 81, 82].includes(c)) return "🌧️";
    if ([71, 73, 75, 77, 85, 86].includes(c)) return "❄️";
    if ([95, 96, 99].includes(c)) return "⛈️";

    return "⛅";
  }

  function weatherDescFromCode(code) {
    const c = Number(code);

    const map = {
      0: "晴朗",
      1: "基本晴",
      2: "局部多云",
      3: "阴天",
      45: "雾",
      48: "冻雾",
      51: "小毛雨",
      53: "毛雨",
      55: "大毛雨",
      56: "冻毛雨",
      57: "强冻毛雨",
      61: "小雨",
      63: "中雨",
      65: "大雨",
      66: "冻雨",
      67: "强冻雨",
      71: "小雪",
      73: "中雪",
      75: "大雪",
      77: "雪粒",
      80: "阵雨",
      81: "强阵雨",
      82: "暴雨",
      85: "阵雪",
      86: "强阵雪",
      95: "雷暴",
      96: "雷暴伴小冰雹",
      99: "雷暴伴大冰雹"
    };

    return map[c] || "天气未知";
  }

  async function geocodeCity(city) {
    const url = `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1&language=zh&format=json`;
    const res = await fetch(url);
    const data = await res.json();

    if (!data || !data.results || !data.results.length) {
      throw new Error("city not found");
    }

    return data.results[0];
  }

  async function fetchWeatherByCity(city) {
    const geo = await geocodeCity(city);
    const lat = geo.latitude;
    const lon = geo.longitude;

    const weatherUrl =
      `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}` +
      `&current=temperature_2m,weather_code` +
      `&daily=weather_code,temperature_2m_max,temperature_2m_min` +
      `&timezone=auto`;

    const res = await fetch(weatherUrl);
    const data = await res.json();

    return {
      cityLabel: WEATHER_CITY_LABELS[city] || geo.name || city,
      current: data.current,
      daily: data.daily
    };
  }

  function renderWeather(type, payload) {
    const iconEl = document.getElementById(`${type}-weather-icon`);
    const cityEl = document.getElementById(`${type}-weather-city`);
    const tempEl = document.getElementById(`${type}-weather-temp`);
    const descEl = document.getElementById(`${type}-weather-desc`);
    const forecastEl = document.getElementById(`${type}-weather-forecast`);

    const current = payload.current || {};
    const daily = payload.daily || {};

    cityEl.textContent = payload.cityLabel || "";
    tempEl.textContent = current.temperature_2m != null ? `${current.temperature_2m}°C` : "天气获取失败";
    descEl.textContent = weatherDescFromCode(current.weather_code);
    iconEl.textContent = weatherIconFromCode(current.weather_code);

    const days = (daily.time || []).slice(0, 3);
    const maxs = daily.temperature_2m_max || [];
    const mins = daily.temperature_2m_min || [];
    const codes = daily.weather_code || [];

    const labels = ["今天", "明天", "后天"];

    forecastEl.innerHTML = days.map((_, i) => {
      const code = codes[i];
      const icon = weatherIconFromCode(code);
      const desc = weatherDescFromCode(code);
      const max = maxs[i] != null ? Math.round(maxs[i]) : "-";
      const min = mins[i] != null ? Math.round(mins[i]) : "-";

      return `
        <div class="weather-forecast-item">
          <div class="weather-forecast-day">${labels[i] || ""}</div>
          <div class="weather-forecast-icon">${icon}</div>
          <div class="weather-forecast-temp">${max}° / ${min}°</div>
          <div class="weather-forecast-desc">${desc}</div>
        </div>
      `;
    }).join("");
  }

  async function updateWeather(type, city) {
    try {
      const payload = await fetchWeatherByCity(city);
      renderWeather(type, payload);
    } catch (e) {
      document.getElementById(`${type}-weather-city`).textContent = city;
      document.getElementById(`${type}-weather-temp`).textContent = "天气获取失败";
      document.getElementById(`${type}-weather-desc`).textContent = "";
      document.getElementById(`${type}-weather-icon`).textContent = "⚠️";
      document.getElementById(`${type}-weather-forecast`).innerHTML = "";
    }
  }

  function bindWeatherSearch(type, defaultCity) {
    const input = document.getElementById(`${type}-city-input`);
    const dropdown = document.getElementById(`${type}-city-dropdown`);
    const options = WEATHER_CITY_OPTIONS[type];

    function renderDropdown(keyword = "") {
      const list = options.filter(city =>
        city.toLowerCase().includes(keyword.toLowerCase())
      );

      if (!list.length) {
        dropdown.innerHTML = "";
        dropdown.classList.remove("show");
        return;
      }

      dropdown.innerHTML = list.map(city => `
        <div class="weather-dropdown-item" data-city="${city}">
          ${WEATHER_CITY_LABELS[city] || city}
        </div>
      `).join("");

      dropdown.classList.add("show");
    }

    input.addEventListener("focus", () => {
      renderDropdown(input.value.trim());
    });

    input.addEventListener("input", () => {
      renderDropdown(input.value.trim());
    });

    dropdown.addEventListener("mousedown", (e) => {
      const item = e.target.closest(".weather-dropdown-item");
      if (!item) return;

      const city = item.getAttribute("data-city");
      input.value = WEATHER_CITY_LABELS[city] || city;
      dropdown.classList.remove("show");
      updateWeather(type, city);
    });

    document.addEventListener("click", (e) => {
      if (!dropdown.contains(e.target) && e.target !== input) {
        dropdown.classList.remove("show");
      }
    });

    updateWeather(type, defaultCity);
    input.value = WEATHER_CITY_LABELS[defaultCity] || defaultCity;
  }

  function updateTimezones() {
    const now = new Date();
    const utcH = now.getUTCHours();
    const m = String(now.getUTCMinutes()).padStart(2, "0");

    const zones = [
      ["tz-east", -4],
      ["tz-central", -5],
      ["tz-mountain", -6],
      ["tz-pacific", -7],
      ["tz-alaska", -8],
      ["tz-hawaii", -10]
    ];

    zones.forEach(([id, off]) => {
      let h = utcH + off;
      if (h < 0) h += 24;
      if (h >= 24) h -= 24;
      document.getElementById(id).textContent = h + ":" + m;
    });
  }

  bindWeatherSearch("cn", "Shenzhen");
  bindWeatherSearch("us", "Los Angeles");
  updateTimezones();
  setInterval(updateTimezones, 60000);
</script>
</body>
</html>
