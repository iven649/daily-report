<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>北美业务情报日报 - {{ date }}</title>

  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
        "PingFang SC", "Microsoft YaHei", Arial, sans-serif;
      background: #f5f5f7;
      color: #111;
    }

    .container {
      max-width: 1200px;
      margin: auto;
      padding: 24px;
    }

    h2 {
      margin: 0 0 12px;
    }

    .card {
      background: white;
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .entity {
      border: 1px solid #eee;
      border-radius: 12px;
      padding: 12px;
    }

    .news-item {
      margin-bottom: 14px;
      border-bottom: 1px solid #eee;
      padding-bottom: 10px;
    }

    .tag {
      display: inline-block;
      padding: 4px 8px;
      background: #f1f1f1;
      border-radius: 999px;
      font-size: 12px;
      margin-right: 6px;
    }

    .note {
      margin-top: 6px;
      font-size: 13px;
      color: #444;
    }

    .product {
      border: 1px solid #eee;
      border-radius: 12px;
      padding: 12px;
    }

  </style>
</head>

<body>
<div class="container">

  <!-- 标题 -->
  <div class="card">
    <h1>北美业务情报日报</h1>
    <div>日期：{{ date }}</div>
    <div>生成时间：{{ generated_at }}</div>
    <div>市场：{{ market_focus }}</div>
  </div>

  <!-- 今日重点 -->
  <div class="card">
    <h2>今日重点</h2>
    <ul>
      {% for item in takeaways %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </div>

  <!-- 重点监控对象（已修复） -->
  <div class="card">
    <h2>重点监控对象</h2>
    <div class="grid-2">
      {% for entity in monitored_entities %}
      <div class="entity">
        <strong>{{ entity["name"] }}</strong>
        <div style="font-size:12px;color:#888;">
          {{ entity["type"] }} · {{ entity["count"] }} 条
        </div>

        <div style="margin-top:8px;">
          {% for item in entity["items"] %}
          <div>
            <a href="{{ item.url }}" target="_blank">
              {{ item.display_title or item.title or item.name }}
            </a>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- 渠道 -->
  <div class="card">
    <h2>渠道与平台变化</h2>

    {% for item in channel_watch %}
    <div class="news-item">
      <a href="{{ item.url }}" target="_blank">
        {{ item.display_title or item.title }}
      </a>

      <div style="font-size:12px;color:#888;">
        {{ item.source }} · {{ item.freshness_label }}
        · {{ item.impact_area }} · {{ item.importance }}
      </div>

      <div>
        {% for tag in item.tags %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>

      <div class="note">
        <strong>业务：</strong>{{ item.business_note }}
      </div>
      <div class="note">
        <strong>动作：</strong>{{ item.suggested_action }}
      </div>
    </div>
    {% endfor %}

  </div>

  <!-- 消费电子 -->
  <div class="card">
    <h2>消费电子重点</h2>

    {% for item in consumer_electronics %}
    <div class="news-item">
      <a href="{{ item.url }}" target="_blank">
        {{ item.display_title or item.title }}
      </a>

      <div style="font-size:12px;color:#888;">
        {{ item.source }} · {{ item.freshness_label }}
        · {{ item.impact_area }} · {{ item.importance }}
      </div>

      <div>
        {% for tag in item.tags %}
        <span class="tag">{{ tag }}</span>
        {% endfor %}
      </div>

      <div class="note">
        <strong>业务：</strong>{{ item.business_note }}
      </div>
      <div class="note">
        <strong>动作：</strong>{{ item.suggested_action }}
      </div>
    </div>
    {% endfor %}

  </div>

  <!-- 新品 -->
  <div class="card">
    <h2>新品速览</h2>

    <div class="grid-2">
      {% for item in products %}
      <div class="product">
        <strong>{{ item.display_title or item.name }}</strong>

        <div style="font-size:12px;color:#888;">
          {{ item.source }} · {{ item.freshness_label }}
        </div>

        <div style="margin-top:6px;">
          {{ item.display_summary or item.summary }}
        </div>

        <div class="note">
          <strong>业务：</strong>{{ item.business_note }}
        </div>

        <div class="note">
          <strong>动作：</strong>{{ item.suggested_action }}
        </div>

        <div style="margin-top:8px;">
          <a href="{{ item.url }}" target="_blank">查看原文</a>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>

  <!-- 节日 -->
  <div class="card">
    <h2>节日与营销节点</h2>

    <div class="grid-2">
      {% for f in festival_cards %}
      <div>
        <strong>{{ f.name }}</strong>
        <div>{{ f.date }} · 还有 {{ f.countdown }} 天</div>
      </div>
      {% endfor %}
    </div>

  </div>

</div>
</body>
</html>
