<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>北美消费电子业务日报 - {{ date }}</title>
  <style>
    :root {
      --bg: #f5f6f8;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --tag-bg: #f3f4f6;
      --pill-bg: #f7f7f8;
      --shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
      --radius-xl: 22px;
      --radius-lg: 18px;
      --radius-md: 14px;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC",
        "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .page {
      max-width: 1440px;
      margin: 0 auto;
      padding: 28px 24px 56px;
    }

    .hero {
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      border: 1px solid rgba(17, 24, 39, 0.05);
      border-radius: 30px;
      box-shadow: var(--shadow);
      padding: 28px 30px;
      margin-bottom: 22px;
    }

    .hero-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .hero-title-wrap h1 {
      margin: 0 0 8px;
      font-size: 30px;
      line-height: 1.15;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .hero-sub {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .hero-badges {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: 999px;
      background: #f3f4f6;
      color: #374151;
      font-size: 12px;
      line-height: 1;
      white-space: nowrap;
    }

    .lead-summary {
      margin-top: 14px;
      font-size: 16px;
      line-height: 1.8;
      color: #1f2937;
      font-weight: 500;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.3fr 0.9fr;
      gap: 18px;
      margin-top: 20px;
    }

    .hero-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 20px 22px;
      min-width: 0;
    }

    .card-kicker {
      font-size: 12px;
      color: var(--muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .lead-story-title {
      display: block;
      font-size: 24px;
      line-height: 1.28;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .lead-story-meta {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 12px;
    }

    .lead-story-note {
      font-size: 15px;
      line-height: 1.8;
      color: #374151;
      margin-bottom: 10px;
    }

    .lead-story-action {
      font-size: 14px;
      line-height: 1.8;
      color: #4b5563;
    }

    .bullet-list {
      margin: 0;
      padding-left: 18px;
    }

    .bullet-list li {
      margin: 0 0 10px;
      line-height: 1.75;
      color: #374151;
      font-size: 14px;
    }

    .section {
      margin-top: 22px;
    }

    .section-box {
      background: var(--card);
      border: 1px solid rgba(17, 24, 39, 0.05);
      border-radius: 30px;
      box-shadow: var(--shadow);
      padding: 22px 22px 20px;
    }

    .section-title {
      margin: 0 0 14px;
      font-size: 18px;
      line-height: 1.2;
      font-weight: 800;
      color: #111827;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .section-card-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .section-card {
      padding: 18px 0;
      border-bottom: 1px solid var(--line);
    }

    .section-card:first-child {
      padding-top: 6px;
    }

    .section-card:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .news-title,
    .product-title {
      display: block;
      font-size: 17px;
      line-height: 1.35;
      font-weight: 700;
      margin-bottom: 8px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: #111827;
    }

    .news-title:hover,
    .product-title:hover,
    .lead-story-title:hover {
      color: #4b5563;
    }

    .news-meta,
    .product-meta {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 10px;
      line-height: 1.6;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 12px;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--tag-bg);
      color: #4b5563;
      font-size: 12px;
      line-height: 1;
      white-space: nowrap;
      border: 1px solid rgba(17, 24, 39, 0.04);
    }

    .news-note {
      font-size: 14px;
      line-height: 1.78;
      color: #374151;
      word-break: break-word;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }

    .product-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 18px 18px 16px;
      min-width: 0;
      min-height: 232px;
      display: flex;
      flex-direction: column;
    }

    .product-summary-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 12px;
    }

    .product-summary {
      min-width: 0;
      flex: 1;
      font-size: 14px;
      color: #44484f;
      line-height: 1.6;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .judgement-pill {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(17, 17, 17, 0.06);
      background: var(--pill-bg);
      color: #4c5158;
      font-size: 12px;
      font-weight: 700;
      line-height: 1;
      white-space: nowrap;
    }

    .festival-grid,
    .signal-grid,
    .watch-grid,
    .feedback-grid {
      display: grid;
      gap: 16px;
    }

    .festival-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .signal-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .watch-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .feedback-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .mini-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 16px 18px;
      min-width: 0;
    }

    .mini-card h3 {
      margin: 0 0 10px;
      font-size: 15px;
      line-height: 1.4;
      font-weight: 700;
    }

    .mini-card p,
    .mini-card li {
      margin: 0;
      font-size: 14px;
      line-height: 1.75;
      color: #374151;
    }

    .entity-type {
      display: inline-flex;
      align-items: center;
      padding: 5px 9px;
      border-radius: 999px;
      background: #f3f4f6;
      color: #4b5563;
      font-size: 12px;
      margin-bottom: 10px;
    }

    .entity-count {
      color: var(--muted);
      font-size: 12px;
      margin-top: 8px;
    }

    .footer-note {
      margin-top: 20px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.7;
      text-align: center;
    }

    @media (max-width: 1200px) {
      .hero-grid,
      .two-col,
      .product-grid,
      .festival-grid,
      .signal-grid,
      .watch-grid,
      .feedback-grid {
        grid-template-columns: 1fr;
      }

      .product-card {
        min-height: unset;
      }
    }

    @media (max-width: 768px) {
      .page {
        padding: 18px 14px 40px;
      }

      .hero,
      .section-box {
        border-radius: 22px;
        padding: 18px 16px;
      }

      .hero-title-wrap h1 {
        font-size: 24px;
      }

      .lead-story-title {
        font-size: 20px;
      }

      .news-title,
      .product-title {
        font-size: 16px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="hero">
      <div class="hero-top">
        <div class="hero-title-wrap">
          <h1>北美消费电子业务日报</h1>
          <div class="hero-sub">
            日期：{{ date }} ｜ 生成时间：{{ generated_at }} ｜ 市场焦点：{{ market_focus }}
          </div>
        </div>
        <div class="hero-badges">
          <span class="hero-badge">消费电子 {{ status.consumer_count }}</span>
          <span class="hero-badge">渠道/平台 {{ status.channel_count }}</span>
          <span class="hero-badge">新品速递 {{ status.product_count }}</span>
        </div>
      </div>

      <div class="lead-summary">{{ lead_summary }}</div>

      <div class="hero-grid">
        <div class="hero-card">
          <div class="card-kicker">Lead Story</div>
          {% if lead_story %}
          <a class="lead-story-title" href="{{ lead_story.url }}" target="_blank">
            {{ lead_story.display_title or lead_story.title or lead_story.name }}
          </a>
          <div class="lead-story-meta">
            {{ lead_story.source }} · {{ lead_story.freshness_label }} · {{ lead_story.importance }} · {{ lead_story.impact_area }}
          </div>
          <div class="tag-row">
            {% for tag in lead_story.tags %}
            <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>
          <div class="lead-story-note">{{ lead_story.business_note }}</div>
          <div class="lead-story-action">建议动作：{{ lead_story.suggested_action }}</div>
          {% else %}
          <div class="lead-story-note">今日暂无足够强的头条信号。</div>
          {% endif %}
        </div>

        <div class="hero-card">
          <div class="card-kicker">今日重点</div>
          <ul class="bullet-list">
            {% for item in takeaways %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-box">
        <div class="two-col">
          <div>
            <h2 class="section-title">消费电子</h2>
            <div class="section-card-list">
              {% for item in consumer_electronics %}
              <article class="section-card">
                <a class="news-title" href="{{ item.url }}" target="_blank" title="{{ item.title }}">
                  {{ item.display_title or item.title }}
                </a>
                <div class="news-meta">{{ item.source }} · {{ item.freshness_label }} · {{ item.importance }} · {{ item.impact_area }}</div>
                <div class="tag-row">
                  {% for tag in item.tags %}
                  <span class="tag">{{ tag }}</span>
                  {% endfor %}
                </div>
                <div class="news-note">{{ item.business_note }}</div>
              </article>
              {% endfor %}
            </div>
          </div>

          <div>
            <h2 class="section-title">渠道 / 平台</h2>
            <div class="section-card-list">
              {% for item in channel_news %}
              <article class="section-card">
                <a class="news-title" href="{{ item.url }}" target="_blank" title="{{ item.title }}">
                  {{ item.display_title or item.title }}
                </a>
                <div class="news-meta">{{ item.source }} · {{ item.freshness_label }} · {{ item.importance }} · {{ item.impact_area }}</div>
                <div class="tag-row">
                  {% for tag in item.tags %}
                  <span class="tag">{{ tag }}</span>
                  {% endfor %}
                </div>
                <div class="news-note">{{ item.business_note }}</div>
              </article>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-box">
        <h2 class="section-title">新品速递</h2>
        <div class="product-grid">
          {% for item in products %}
          <article class="product-card">
            <a class="product-title" href="{{ item.url }}" target="_blank" title="{{ item.name or item.display_title }}">
              {{ item.display_title or item.name }}
            </a>
            <div class="product-meta">{{ item.source }} · {{ item.freshness_label }} · {{ item.importance }}</div>
            <div class="tag-row">
              {% for tag in item.tags %}
              <span class="tag">{{ tag }}</span>
              {% endfor %}
            </div>
            <div class="product-summary-row">
              <div class="product-summary" title="{{ item.product_intro or item.display_summary or item.summary }}">
                {{ item.product_intro or item.display_summary or item.summary }}
              </div>
              <span class="judgement-pill">{{ item.judgement_label or "业务观察" }}</span>
            </div>
            <div class="news-note">{{ item.business_note }}</div>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    {% if festival_cards %}
    <section class="section">
      <div class="section-box">
        <h2 class="section-title">节日 / 促销节点</h2>
        <div class="festival-grid">
          {% for item in festival_cards %}
          <article class="mini-card">
            <h3>
              {% if item.slug %}
              <a href="{{ item.slug }}.html">{{ item.icon }} {{ item.name }}</a>
              {% else %}
              {{ item.icon }} {{ item.name }}
              {% endif %}
            </h3>
            <p>{{ item.date }} ｜ 倒计时 {{ item.countdown }} 天</p>
            {% if item.note %}
            <p style="margin-top: 8px;">{{ item.note }}</p>
            {% endif %}
          </article>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    <section class="section">
      <div class="section-box">
        <h2 class="section-title">机会提示 / 风险提示</h2>
        <div class="signal-grid">
          <article class="mini-card">
            <h3>机会提示</h3>
            <ul class="bullet-list">
              {% for item in opportunity_signals %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </article>

          <article class="mini-card">
            <h3>风险提示</h3>
            <ul class="bullet-list">
              {% for item in risk_signals %}
              <li>{{ item }}</li>
              {% endfor %}
            </ul>
          </article>
        </div>
      </div>
    </section>

    {% if monitored_entities %}
    <section class="section">
      <div class="section-box">
        <h2 class="section-title">重点监控对象</h2>
        <div class="watch-grid">
          {% for entity in monitored_entities %}
          <article class="mini-card">
            <div class="entity-type">{{ entity.type }}</div>
            <h3>{{ entity.name }}</h3>
            <div class="entity-count">命中 {{ entity.count }} 次</div>
            {% if entity.items %}
            <ul class="bullet-list" style="margin-top: 10px;">
              {% for item in entity.items %}
              <li>{{ item.display_title or item.title or item.name }}</li>
              {% endfor %}
            </ul>
            {% endif %}
          </article>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    {% if feedback_items %}
    <section class="section">
      <div class="section-box">
        <h2 class="section-title">复盘建议</h2>
        <div class="feedback-grid">
          {% for item in feedback_items %}
          <article class="mini-card">
            <p>{{ item }}</p>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    <div class="footer-note">
      自动生成页面 ｜ 状态：{{ status.source_summary }} ｜ 规则：{{ status.freshness_rule }}
    </div>
  </div>
</body>
</html>
