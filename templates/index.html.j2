<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>分销日报 - {{ date }}</title>

  <style>
    :root {
      --bg: #f5f5f7;
      --card: #ffffff;
      --text: #111;
      --muted: #6e6e73;
      --line: rgba(0,0,0,0.06);
    }

    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI";
      background:
        linear-gradient(to right, rgba(0,0,0,0.02) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(0,0,0,0.02) 1px, transparent 1px),
        #f8f8fa;
      background-size: 40px 40px;
    }

    .container {
      max-width: 1100px;
      margin: auto;
      padding: 30px 20px;
    }

    .card {
      background: var(--card);
      border-radius: 20px;
      padding: 20px;
      margin-bottom: 16px;
      border: 1px solid var(--line);
    }

    h1 {
      font-size: 42px;
      margin: 0;
      letter-spacing: -1px;
    }

    h2 {
      font-size: 18px;
      margin-bottom: 12px;
    }

    .top {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .date {
      font-size: 22px;
      font-weight: 600;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .news-item {
      padding: 12px 0;
      border-bottom: 1px solid var(--line);
    }

    .news-title {
      font-size: 16px;
      font-weight: 600;
    }

    .news-source {
      font-size: 13px;
      color: var(--muted);
    }

    .product {
      border: 1px solid var(--line);
      padding: 14px;
      border-radius: 14px;
      margin-bottom: 10px;
    }

    .product-title {
      font-weight: 700;
      margin-bottom: 6px;
    }

    .product-summary {
      font-size: 14px;
      color: #444;
    }

    /* 今日重点 */
    .takeaways li {
      margin-bottom: 10px;
      line-height: 1.7;
    }

    /* 时区 */
    .tz {
      display: grid;
      grid-template-columns: repeat(3,1fr);
      gap: 10px;
    }

    .tz div {
      background: #fafafa;
      padding: 10px;
      border-radius: 10px;
      text-align: center;
    }

    /* 反馈 */
    .feedback {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .btn {
      background: black;
      color: white;
      padding: 10px 16px;
      border-radius: 20px;
      text-decoration: none;
    }

  </style>
</head>

<body>
<div class="container">

  <!-- 顶部 -->
  <div class="card top">
    <h1>分销日报</h1>
    <div class="date">{{ date }}</div>
  </div>

  <!-- 时区 -->
  <div class="card">
    <h2>🕐 美国时区</h2>
    <div class="tz">
      <div>EST<br><span id="tz-east"></span></div>
      <div>CST<br><span id="tz-central"></span></div>
      <div>MST<br><span id="tz-mountain"></span></div>
      <div>PST<br><span id="tz-pacific"></span></div>
      <div>AKST<br><span id="tz-alaska"></span></div>
      <div>HST<br><span id="tz-hawaii"></span></div>
    </div>
  </div>

  <!-- 今日重点 -->
  <div class="card">
    <h2>今日重点</h2>

    <ul class="takeaways">
      {% if takeaways %}
        {% for item in takeaways %}
        <li>{{ item }}</li>
        {% endfor %}
      {% else %}
        <li>暂无重点</li>
      {% endif %}
    </ul>

  </div>

  <!-- 新闻 -->
  <div class="grid-2">

    <div class="card">
      <h2>📰 今日热点</h2>
      {% for item in consumer_electronics %}
      <div class="news-item">
        <a class="news-title" href="{{ item.url }}" target="_blank">
          {{ item.display_title or item.title }}
        </a>
        <div class="news-source">{{ item.source }}</div>
      </div>
      {% endfor %}
    </div>

    <div class="card">
      <h2>🛒 渠道新闻</h2>
      {% for item in channel_news %}
      <div class="news-item">
        <a class="news-title" href="{{ item.url }}" target="_blank">
          {{ item.display_title or item.title }}
        </a>
        <div class="news-source">{{ item.source }}</div>
      </div>
      {% endfor %}
    </div>

  </div>

  <!-- 新品 -->
  <div class="card">
    <h2>🚀 新品速递</h2>

    {% for item in products %}
    <div class="product">
      <div class="product-title">
        {{ item.display_title or item.name }}
      </div>
      <div class="product-summary">
        {{ item.display_summary or item.summary }}
      </div>
      <a href="{{ item.url }}" target="_blank">查看原文 →</a>
    </div>
    {% endfor %}

  </div>

  <!-- 反馈 -->
  <div class="card feedback">
    <div>
      <div style="font-weight:700;">反馈与建议</div>
      <div style="font-size:14px;color:#666;">帮助我们优化日报</div>
    </div>

    <a href="https://docs.google.com/forms/d/e/1FAIpQLSdyWZwDTGRplMGv6EWojLPp3VjaKpsv_DqKaS0XyXiayPf7hg/viewform"
       target="_blank"
       class="btn">
       提交反馈
    </a>
  </div>

</div>

<script>
function updateTimezones() {
  const now = new Date();
  const utcH = now.getUTCHours();
  const m = String(now.getUTCMinutes()).padStart(2,"0");

  const zones = [
    ["tz-east",-4],
    ["tz-central",-5],
    ["tz-mountain",-6],
    ["tz-pacific",-7],
    ["tz-alaska",-8],
    ["tz-hawaii",-10]
  ];

  zones.forEach(([id,off])=>{
    let h = utcH+off;
    if(h<0)h+=24;
    if(h>=24)h-=24;
    document.getElementById(id).innerText = h+":"+m;
  });
}

updateTimezones();
setInterval(updateTimezones,60000);
</script>

</body>
</html>
