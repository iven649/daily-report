<!-- 新品速递 -->
<div class="card">
  <h2>🚀 新品速递</h2>

  <div class="grid">
    {% for item in products %}
    <div class="product-card">

      <!-- 标题 -->
      <div class="title">
        {{ item.display_title or item.name }}
      </div>

      <!-- 来源 + 时间 -->
      <div class="meta">
        {{ item.source }} · {{ item.date }}
      </div>

      <!-- 摘要 -->
      <div class="summary">
        {{ item.display_summary or item.summary }}
      </div>

      <!-- 链接 -->
      <a href="{{ item.url }}" target="_blank" class="link">
        查看原文 →
      </a>

    </div>
    {% endfor %}
  </div>
</div>
